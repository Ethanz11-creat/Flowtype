# SiliconFlow API Key
# 从 https://cloud.siliconflow.cn/account/ak 获取
SILICONFLOW_API_KEY=your_api_key_here

# ASR 模型配置
ASR_PRIMARY_MODEL=TeleAI/TeleSpeechASR
ASR_FALLBACK_MODEL=FunAudioLLM/SenseVoiceSmall

# LLM 模型配置
LLM_MODEL=deepseek-ai/DeepSeek-V3

# --- ASR Engineering Optimizations ---

# Dump recorded audio to ~/Library/Logs/flowtype/ for debugging
# FLOWTYPE_DUMP_AUDIO=1

# ASR provider strategy: "parallel" (default, run both and score) or "fallback" (sequential)
# ASR_STRATEGY=parallel

# Post-processing switches
# ENABLE_FILLER_STRIP=1
# ENABLE_TERM_CORRECTION=1
